{
    "dataset_link": "geadalfa/cracked-non-cracked-surface-datasets",
    "split_ratios": [
        0.8,
        0.15,
        0.05
    ],
    "global": {
        "image_size": [
            224,
            224
        ],
        "num_classes": 2,
        "seed": 42,
        "early_stopping_patience": 15,
        "reduce_lr_factor": 0.5,
        "reduce_lr_patience": 5,
        "monitor": "val_loss",
        "n_trials": 30
