                    "type": "int",
                    "min": 512,
                    "max": 1024,
                    "step": 64
                },
                "dropout_rate": {
                    "type": "float",
                    "min": 0.1,
                    "max": 0.5
                },
                "learning_rate": {
                    "type": "float",
                    "min": 1e-05,
                    "max": 0.01,
                    "log": true
                }
            },
            "best": {
                "val_accuracy": 0.0,
                "batch_size": 32,
